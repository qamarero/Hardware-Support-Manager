{
  "mcpServers": {
    "neon": {
      "type": "http",
      "url": "https://mcp.neon.tech/mcp"
    },
    "postgresql": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres"
      ],
      "env": {
        "POSTGRES_CONNECTION_STRING": "postgresql://user:password@localhost:5432/dbname"
      }
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=thkrkubkiasfqmiiwfbj"
    },
    "web-fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/fetch-mcp"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      }
    },
    "markitdown": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/markitdown-mcp"
      ]
    },
    "figma": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/figma-mcp"
      ],
      "env": {
        "FIGMA_ACCESS_TOKEN": ""
      }
    }
  }
}