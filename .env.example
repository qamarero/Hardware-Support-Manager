# Supabase PostgreSQL connection string (pooler, transaction mode)
# Format: postgresql://[role].[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# HSM uses a dedicated 'hsm_app' role with its own schema 'hsm'
DATABASE_URL=postgresql://hsm_app.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# NextAuth.js
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Vercel Blob (for file attachments)
BLOB_READ_WRITE_TOKEN=vercel-blob-token-here
