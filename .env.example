# Supabase PostgreSQL connection string (pooler, transaction mode)
# Format: postgresql://[role].[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# HSM uses a dedicated 'hsm_app' role with its own schema 'hsm'
DATABASE_URL=postgresql://hsm_app.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# NextAuth.js
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Vercel Blob (for file attachments)
BLOB_READ_WRITE_TOKEN=vercel-blob-token-here

# Intercom API
INTERCOM_ACCESS_TOKEN=your-intercom-access-token
INTERCOM_WEBHOOK_SECRET=your-intercom-webhook-secret
# Admin user ID that posts internal notes to Intercom from HSM sync.
# Obtain via: curl -s https://api.intercom.io/admins -H "Authorization: Bearer $INTERCOM_ACCESS_TOKEN" -H "Intercom-Version: 2.11"
# Pick the admin ID that should own automated notes (e.g. your support lead).
# REQUIRED for sync to work — without this, notes silently fail in Intercom.
INTERCOM_ADMIN_ID=your-intercom-admin-id

# External API (HW Main Portal integration)
# Shared secret used by the HW Main Portal to fetch /api/external/metrics
# Header expected: X-API-Key
MAIN_PORTAL_API_KEY=generate-with-openssl-rand-base64-32

# External API (Public incidents endpoint)
# Shared secret for /api/external/incidents — detailed incident data + PII.
# Used by third-party tools (CRM, analytics, etc.) authorized to access
# full incident data. Generate with: openssl rand -base64 32
# Header expected: X-API-Key
# REQUIRED if /api/external/incidents is consumed — otherwise returns 503.
HSM_PUBLIC_API_KEY=generate-with-openssl-rand-base64-32
